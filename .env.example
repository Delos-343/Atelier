# ─── Supabase project — CLIENT (used by the browser; safe to expose) ───
# Project Settings → API. The URL is the https API endpoint.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# The client key. Either variable name works:
#   NEXT_PUBLIC_SUPABASE_ANON_KEY         (legacy "anon" key)
#   NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY  (Supabase's newer "publishable" key, sb_publishable_…)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# ─── Supabase service-role key — SERVER ONLY (admin account create / delete) ───
# Project Settings → API → `service_role` key (secret). Enables creating and deleting
# login accounts from the admin Users screen. NOTE: no NEXT_PUBLIC_ prefix — this is a
# god-mode key that bypasses RLS and must never reach the browser. Leave it unset and
# account management degrades gracefully (role assignment still works); set it to turn
# on account create / delete.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ─── App URL — OPTIONAL (email-invitation redirect) ───
# Public origin of this app, used to build the invitation accept link
# (<origin>/accept-invite). When unset, the origin is derived from the request;
# set it if the app runs behind a proxy that rewrites the host. Also add
# <origin>/accept-invite to Supabase → Auth → URL Configuration → Redirect URLs,
# and configure SMTP so invitation emails actually send.
NEXT_PUBLIC_SITE_URL=https://your-app.example.com

# ─── SMTP — OPTIONAL (email issued documents to customers) ───
# Enables the "Email…" action on issued documents (invoice / packing slip / credit
# note): the frozen PDF is attached and every send is recorded. Any provider's SMTP
# endpoint works — Resend, SES, Mailgun, Postmark, or a corporate relay — typically
# the same credentials you'd give Supabase for auth invitation emails. Leave unset
# and the action is disabled with a note; nothing else changes.
# Required to enable: SMTP_HOST + MAIL_FROM. Optional: port (default 587),
# credentials (leave both unset for an IP-authorised relay), and SMTP_SECURE=true to
# force implicit TLS (otherwise inferred: true on port 465, STARTTLS elsewhere).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=smtp-username
SMTP_PASS=smtp-password
# SMTP_SECURE=true
# The From header on outgoing documents — an address your provider allows you to send as.
MAIL_FROM="TechnicoFlor <documents@your-domain.example>"

# ─── Postgres connection — MIGRATIONS & TESTS ONLY (never the app at runtime) ───
# This is consumed by `pg`, so it MUST be a postgresql:// URI with your DB PASSWORD —
# NOT the https API URL above, and NOT the publishable key.
#
# • Local test DB (for `yarn test:*`):
DATABASE_URL=postgres://postgres:postgres@localhost:5432/erp_test
#
# • To push this schema to a Supabase project instead, copy the "Session pooler" URI from
#   Project Settings → Database → Connection string (IPv4-friendly), e.g.:
#   postgresql://postgres.<project-ref>:[YOUR-DB-PASSWORD]@aws-0-<region>.pooler.supabase.com:5432/postgres

# ─── Security layer — ALL OPTIONAL (v0.50) ─────────────────────────────────
# The security hardening (rate limiting, CAPTCHA, WAF-lite + security headers)
# ships ON with safe defaults and needs NOTHING here to function. These vars only
# upgrade or tune it. With everything unset: in-memory per-instance rate limiting,
# no CAPTCHA challenge, and the always-on header/request filter.

# Cloudflare Turnstile — CAPTCHA on the login form. This SITE key is public (safe
# in the browser). The matching SECRET key is set in the Supabase dashboard
# (Auth → Settings → Enable CAPTCHA protection → Turnstile), because Supabase
# verifies the token server-side on sign-in — this app never needs the secret.
# Unset ⇒ the login form shows no challenge and behaves exactly as before.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA-your-turnstile-site-key

# Upstash Redis (REST) — durable, cross-instance rate-limit store. Without these
# the limiter uses an in-memory window that is per-instance and resets on
# redeploy (fine for a single instance / preview, not for multi-lambda prod).
# Create a database at upstash.com and copy the REST URL + token.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Master switches (default ON). Set to "off" to disable a layer — e.g. when a real
# WAF/CDN already fronts the app and you'd rather not double-filter or throttle.
# SECURITY_RATE_LIMIT=off
# SECURITY_WAF=off
